# Google Gemini API Key - required for IaC generation
# Get yours free at https://aistudio.google.com/app/apikey


# GitHub Personal Access Token - required for GitHub URL analysis
# Create one at https://github.com/settings/tokens (classic, no scopes needed for public repos)
GITHUB_TOKEN=your_github_pat_here

# Server config
PORT=5000

# AWS config (optional - used for Terraform variable defaults)
AWS_REGION=us-east-1
AWS_PROFILE=default
